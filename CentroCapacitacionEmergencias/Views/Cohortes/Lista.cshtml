
@model CentroCapacitacionEmergencias.ViewModels.CohorteViewModel

@{
    ViewBag.Title = "ListaCohortes";
}

@{
    var usuario = @Session["UserName"];
    var rol = @Session["UserRole"] as string;
}

<h2>ListaCohortes</h2>

<table class="table table-striped table-bordered w-100">



    <thead class="table-dark ">
        <tr>
            <th>Nombre</th>
            <th>Fecha Inicio</th>
            <th>Fecha Fin</th>
            <th>Acciones</th>

        </tr>
    </thead>

    <tbody>

        @foreach (var item in Model.Cohortes)
        {
            <tr>
                <td>@item.Nombre</td>
                <td>@item.FechaInicio</td>
                <td>@item.FechaFin</td>
                <td>
                    @if (usuario != null && rol == "Administrador")
                    {
                        <a href="@Url.Action("Editar","Cohortes", new { id = item.Id })"
                           class="btn btn-sm btn-warning">
                            Editar
                        </a>

                        <a href="@Url.Action("Delete","Cohortes", new { id = item.Id })"
                           class="btn btn-sm btn-danger">
                            Eliminar
                        </a>


                    }


                </td>
            </tr>
        }

    </tbody>

</table>