
@model CentroCapacitacionEmergencias.ViewModels.ParticipanteViewModel

@{
    ViewBag.Title = "Registrar Participante";
}

<h2 class="mb-4">Registrar Participante</h2>

@if (!ViewData.ModelState.IsValid)
{
    <div class="alert alert-danger">
        <strong>Por favor corrija los siguientes errores:</strong>
        @Html.ValidationSummary(false)
    </div>
}

@using (Model.Id != 0 ? Html.BeginForm("EditarParticipante", "Participantes", FormMethod.Post) : Html.BeginForm())
{
    @Html.AntiForgeryToken()

    <div class="card p-4 shadow-sm">

        @Html.HiddenFor(m => m.Id)

        <h5 class="mb-3">Información Personal</h5>

        <div class="row">

            <div class="col-md-4 mb-3">
                <label>Tipo Identificación</label>
                @if(Model.Id == 0)
                {
                    @Html.DropDownListFor(m => m.TipoIdentificacion,
                    new SelectList(new[] { "Cedula", "DIMEX", "Pasaporte" }),
                    "Seleccione",
                    new { @class = "form-control"})
                }
                else
                {
                    @Html.TextBoxFor(m => m.TipoIdentificacion, new { @class = "form-control",@readonly = "readonly"   })
                } 
                @Html.ValidationMessageFor(m => m.TipoIdentificacion, "", new { @class = "text-danger" })
            </div>

            <div class="col-md-4 mb-3">
                <label>Identificación</label>
                @if(Model.Id == 0)
                {
                    @Html.TextBoxFor(m => m.Identificacion, new { @class = "form-control" })
                }
                else
                {
                    @Html.TextBoxFor(m => m.Identificacion, new { @class = "form-control",@readonly = "readonly"   })
                }
                @Html.ValidationMessageFor(m => m.Identificacion, "", new { @class = "text-danger" })
            </div>

            <div class="col-md-4 mb-3">
                <label>Estado Civil</label>
                @Html.DropDownListFor(m => m.EstadoCivil,
                new SelectList(new[] { "Soltero", "Casado", "Divorciado", "Viudo" }),
                "Seleccione",
                new { @class = "form-control" })
            </div>

        </div>

        <div class="mb-3">
            <label>Nombre Completo</label>
            @Html.TextBoxFor(m => m.NombreCompleto, new { @class = "form-control" })
            @Html.ValidationMessageFor(m => m.NombreCompleto, "", new { @class = "text-danger" })
        </div>

        <div class="mb-3">
            <label>Fecha de Nacimiento</label>
            @Html.TextBoxFor(m => m.FechaNacimiento, new { @type = "date", @class = "form-control" })
        </div>


        <hr class="my-4" />

        <h5 class="mb-3">Residencia</h5>

        <div class="row">

            <div class="col-md-4 mb-3">
                <label>Provincia</label>
                @Html.TextBoxFor(m => m.Provincia, new { @class = "form-control" })
            </div>

            <div class="col-md-4 mb-3">
                <label>Cantón</label>
                @Html.TextBoxFor(m => m.Canton, new { @class = "form-control" })
            </div>

            <div class="col-md-4 mb-3">
                <label>Distrito</label>
                @Html.TextBoxFor(m => m.Distrito, new { @class = "form-control" })
            </div>

        </div>

        <div class="mb-3">
            <label>Detalle Dirección</label>
            @Html.TextBoxFor(m => m.DetalleDireccion, new { @class = "form-control" })
        </div>


        <hr class="my-4" />

        <h5 class="mb-3">Contacto</h5>

        <div class="mb-3">
            <label>Correo Electrónico</label>
            @Html.TextBoxFor(m => m.Correo, new { @class = "form-control" })
            @Html.ValidationMessageFor(m => m.Correo, "", new { @class = "text-danger" })
        </div>

        <div class="row">

            <div class="col-md-6 mb-3">
                <label>Teléfono</label>
                @Html.TextBoxFor(m => m.Telefono, new { @class = "form-control" })
            </div>

            <div class="col-md-6 mb-3">
                <label>Contacto de Emergencia</label>
                @Html.TextBoxFor(m => m.ContactoEmergencia, new { @class = "form-control" })
            </div>

        </div>

        <div class="mb-3">
            <label>Dirección de Residencia</label>
            @Html.TextBoxFor(m => m.DireccionResidencia, new { @class = "form-control" })
        </div>

        <hr />

        @if(Model.Id == 0)
        {
             <button type="submit" class="btn btn-primary">
                Registrar Participante
            </button>
        }else 
        {
            <button type="submit" class="btn btn-warning">
                    Actuaizar Participante
             </button>
        }

       
        <br />
        <a href="@Url.Action("Index","Home")" class="btn btn-secondary">
            Cancelar
        </a>

    </div>

}