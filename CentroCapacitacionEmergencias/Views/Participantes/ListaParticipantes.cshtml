
@model CentroCapacitacionEmergencias.ViewModels.ParticipanteViewModel

@{
    var detalle = ViewBag.ParticipanteDetalle as CentroCapacitacionEmergencias.Models.Participante;
    var evaluar = ViewBag.ParticipanteEvaluar as CentroCapacitacionEmergencias.Models.Participante;
    var cursos = ViewBag.Cursos as List<CentroCapacitacionEmergencias.Models.Curso>;
    var cohortes = ViewBag.Cohortes as List<CentroCapacitacionEmergencias.Models.Cohorte>;
    var destrezas = ViewBag.destrezas as List<CentroCapacitacionEmergencias.Models.Destreza>;


}


@{
    var usuario = @Session["UserName"];
    var rol = @Session["UserRole"] as string;
}

<h2 class="mb-4">Lista de Participantes</h2>

@if (usuario != null && rol == "Administrador")
{
    <div class="mb-3">
        <a href="@Url.Action("Create","Participantes")" class="btn btn-primary">
            Nuevo Participante
        </a>
    </div>
}


<table class="table table-striped table-bordered w-100">

    @using (Html.BeginForm("ListaParticipantes", "Participantes", FormMethod.Get))
    {
        <div class="row mb-3">

            <div class="col-md-3">
                @Html.TextBoxFor(m => m.filtroNombre,
                new { @class = "form-control", placeholder = "Nombre" })
            </div>

            <div class="col-md-3">
                @Html.TextBoxFor(m => m.filtroCedula,
                new { @class = "form-control", placeholder = "Cédula" })
            </div>

            <div class="col-md-3">
                @Html.DropDownListFor(
                m => m.filtroCohorteId,
                Model.Cohortes,
                "Seleccione Cohorte",
                new { @class = "form-control" })
            </div>

            <div class="col-md-3">
                @Html.DropDownListFor(
                m => m.filtroCursoId,
                Model.Cursos,
                "Seleccione Curso",
                new { @class = "form-control" })
            </div>

            <div class="col-md-2">
                <button class="btn btn-primary">
                    Buscar
                </button>
            </div>

        </div>
    }

    <thead class="table-dark ">
        <tr>
            <th>ID</th>
            <th>Nombre</th>
            <th>Identificación</th>
            <th>Correo</th>
            <th>Teléfono</th>
            <th>Provincia</th>
            <th>Acciones</th>
        </tr>
    </thead>

    <tbody>

        @foreach (var item in Model.Participantes)
        {
            <tr>
                <td>@item.Id</td>
                <td>@item.NombreCompleto</td>
                <td>@item.Identificacion</td>
                <td>@item.Correo</td>
                <td>@item.Telefono</td>
                <td>@item.Provincia</td>

                <td>
                    @if (usuario != null && rol == "Instructor")
                    {

                        <a href="@Url.Action("ListaParticipantes",new { evaluacionId = item.Id })"
                           class="btn btn-sm btn-info">
                            Evaluación
                        </a>

                        <a href="@Url.Action("ListaParticipantes",new { detalleId = item.Id })"
                           class="btn btn-sm btn-info">
                            Detalles
                        </a>

                    }



                    @if (usuario != null && rol == "Administrador")
                    {
                        <a href="@Url.Action("Asignar","Asignar", new { id = item.Id })"
                           class="btn btn-sm btn-success">
                            Añadir Cursos y Cohorte
                        </a>

                        <a href="@Url.Action("Editar","Participantes", new { id = item.Id })"
                           class="btn btn-sm btn-warning">
                            Editar
                        </a>


                        <a href="@Url.Action("Delete","Participantes", new { id = item.Id })"
                           class="btn btn-sm btn-danger">
                            Eliminar
                        </a>


                    }


                </td>
            </tr>
        }

    </tbody>

</table>

@if (detalle != null)
{

    <div class="modal fade show" style="display:block;" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">

                <div class="modal-header">
                    <h5 class="modal-title">Detalle del Participante</h5>
                    <a href="@Url.Action("ListaParticipantes")" class="btn-close"></a>
                </div>

                <div class="modal-body">

                    <p><strong>Nombre:</strong> @detalle.NombreCompleto</p>

                    <p><strong>Identificación:</strong> @detalle.Identificacion</p>

                    <p><strong>Correo:</strong> @detalle.Correo</p>

                    <p><strong>Teléfono:</strong> @detalle.Telefono</p>

                    <p><strong>Provincia:</strong> @detalle.Provincia</p>

                    <p><strong>Cantón:</strong> @detalle.Canton</p>

                    <p><strong>Distrito:</strong> @detalle.Distrito</p>

                    <p><strong>Estado Civil:</strong> @detalle.EstadoCivil</p>

                    <p><strong>Dirección:</strong> @detalle.DetalleDireccion</p>


                    <hr />
                    @if (cohortes != null && cohortes.Any())
                    {

                        <table class="table table-striped">

                            <thead>
                                <tr>
                                    <th>Cohorte</th>
                                    <th>Fecha Inicio</th>
                                    <th>Fecha Final</th>
                                    @if (usuario != null && rol == "Administrador")
                                    {
                                        <th>Acciones</th>
                                    }
                                </tr>
                            </thead>

                            <tbody>

                                @foreach (var cohorte in cohortes)
                                {
                                    <tr>
                                        <td>@cohorte.Nombre</td>
                                        <td>@cohorte.FechaInicio</td>
                                        <td>@cohorte.FechaFin</td>


                                        @if (usuario != null && rol == "Administrador")
                                        {
                                            <td>
                                                <a href="@Url.Action("RemoverCohorte","Participantes", new { idCohorte = cohorte.Id,idParticipante = detalle.Id})"
                                                   class="btn btn-sm btn-warning">
                                                    Remover Cohorte
                                                </a>
                                            </td>
                                        }




                                    </tr>
                                }

                            </tbody>

                        </table>

                    }
                    else
                    {

                        <div class="alert alert-info">
                            Este participante no tiene cohortes asignados.
                        </div>

                    }

                    <hr />
                    <h5>Cursos asignados</h5>

                    @if (cursos != null && cursos.Any())
                    {

                        <table class="table table-striped">

                            <thead>
                                <tr>
                                    <th>Curso</th>
                                    <th>Código</th>
                                    <th>Horas Prácticas</th>
                                    @if (usuario != null && rol == "Administrador")
                                    {
                                        <th>Acciones</th>
                                    }
                                </tr>
                            </thead>

                            <tbody>

                                @foreach (var curso in cursos)
                                {
                                    <tr>
                                        <td>@curso.Titulo</td>
                                        <td>@curso.CodigoCurso</td>
                                        <td>@curso.HorasPracticas</td>
                                        @if (usuario != null && rol == "Administrador")
                                        {
                                            <td>
                                                <a href="@Url.Action("RemoverCurso","Participantes", new { idCurso = curso.Id,idParticipante = detalle.Id})"
                                                   class="btn btn-sm btn-warning">
                                                    Remover Curso
                                                </a>
                                            </td>
                                        }
                                    </tr>
                                }

                            </tbody>

                        </table>

                    }
                    else
                    {

                        <div class="alert alert-info">
                            Este participante no tiene cursos asignados.
                        </div>

                    }

                </div>



            </div>
        </div>
    </div>

    <div class="modal-backdrop fade show"></div>

}


@if (evaluar != null)
{

    <div class="modal fade show" style="display:block;" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">

                <div class="modal-header">
                    <h5 class="modal-title">Evaluación Destrezas de 
                        <strong>
                            @Model.ParticipanteEvaluado
                        </strong>
                    </h5>
                    <a href="@Url.Action("ListaParticipantes")" class="btn-close"></a>
                </div>

                <div class="modal-body">

                    <hr />
                    <h5>
                        Cursos por Evaluar:
                        <strong>
                            @Model.CursoTituloEvaluar
                        </strong>
                    </h5>


                    @using (Html.BeginForm("ListaParticipantes", "Participantes", FormMethod.Get))
                    {
                        <div class="col-md-3">
                            @Html.TextBoxFor(m => m.evaluacionId,
                            new { @class = "form-control", @readonly = "readonly" })
                        </div>
                        <br>
                        <div class="col-md-4">
                            @Html.DropDownListFor(
                            m => m.CursoIdEvaluar,
                            Model.CursosPorEvaluar,
                            "Seleccione un Curso",
                            new { @class = "form-control", onchange = "this.form.submit();" })
                        </div>
                    }

                    <br>
                    <hr>

                    <div class="row mb-3">

                        @if (Model.destrezasParticipante != null)
                        {
                            <table class="table">
                                <thead>
                                    <tr>
                                        <th>Destreza</th>
                                        <th>Descripción</th>
                                        <th>Acciones</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var destreza in Model.destrezasParticipante)
                                    {
                                        <tr>
                                            <td>@destreza.Titulo</td>
                                            <td>@destreza.Descripcion</td>
                                            <td>
                                                @if (usuario != null && rol == "Instructor")
                                                {

                                                    <a href="@Url.Action("Evaluacion","Evaluacion",new {idCurso = @Model.CursoIdEvaluar,idParticipante = @Model.evaluacionId,idDestreza = destreza.Id})"
                                                       class="btn btn-sm btn-info">
                                                        Evaluar Destreza
                                                    </a>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        }

                    </div>



                </div>



                </div>
        </div>
    </div>

    <div class="modal-backdrop fade show"></div>

}



