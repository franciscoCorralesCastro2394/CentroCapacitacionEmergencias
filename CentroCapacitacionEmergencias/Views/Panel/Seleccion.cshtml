


<h2>Seleccion</h2>


@using (Html.BeginForm("Index", "Panel", FormMethod.Get))
{
    <div class="row mb-3">

        <div class="col-md-3">
            @Html.DropDownList(
            "idCurso",
            (IEnumerable<SelectListItem>)ViewBag.Cursos,
            "Seleccione el curso",
            new { @class = "form-control" })
        </div>

        <div class="col-md-3">
            @Html.DropDownList(
            "idCohorte",
            (IEnumerable<SelectListItem>)ViewBag.Cohortes,
            "Seleccione el Cohorte",
            new { @class = "form-control" })
        </div>

        <div class="col-md-2">
            <button class="btn btn-primary">
                Buscar
            </button>
        </div>

    </div>
}

